#!/bin/bash
# Auto-download gradle if not present
if [ ! -f "$PWD/gradle/wrapper/gradle-wrapper.jar" ]; then
  echo "Downloading gradle wrapper..."
  mkdir -p "$PWD/gradle/wrapper"
  wget -q https://raw.githubusercontent.com/gradle/gradle/v8.5.0/gradle/wrapper/gradle-wrapper.jar -O "$PWD/gradle/wrapper/gradle-wrapper.jar"
fi
java -cp "$PWD/gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
